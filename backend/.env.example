# ── Database ───────────────────────────────────────────────────────────────────
# PostgreSQL connection string
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:senha123@localhost:5432/delicias_mirian"

# ── JWT Secret ────────────────────────────────────────────────────────────────
# Gere uma chave forte: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="troque-essa-chave-por-uma-muito-segura-em-producao"

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Frontend URL (para CORS) ──────────────────────────────────────────────────
# Em desenvolvimento:
FRONTEND_URL=http://localhost:5173
# Em produção: FRONTEND_URL=https://seusite.vercel.app
